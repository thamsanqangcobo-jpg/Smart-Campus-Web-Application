@page
@model SmartCampusPortal.Pages.SOS.DetailsModel
@{
    ViewData["Title"] = "Incident Report Details";
}

<h1>Incident Report Details</h1>

<div>
    <h4>Incident Report</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Type</dt>
        <dd class="col-sm-10">@Model.IncidentReport.IncidentType</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.IncidentReport.Description</dd>

        <dt class="col-sm-2">Location</dt>
        <dd class="col-sm-10">@Model.IncidentReport.Location</dd>

        <dt class="col-sm-2">Report Date</dt>
        <dd class="col-sm-10">@Model.IncidentReport.ReportDate.ToShortDateString()</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.IncidentReport.Status</dd>
    </dl>
</div>
<p>
    <a asp-page="./SOSIndex" class="btn btn-primary">Back to List</a>
</p>
