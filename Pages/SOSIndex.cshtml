@page
@model SmartCampusPortal.Pages.SOSIndexModel
@{
    ViewData["Title"] = "SOS Reports";
}

<h1>SOS Reports</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <strong>Please correct the following errors:</strong>
        <ul>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<h2>Submit a New Incident Report</h2>
<form method="post" class="sos-form">
    <div class="form-group">
        <label asp-for="NewIncident.IncidentType">Incident Type</label>
        <input asp-for="NewIncident.IncidentType" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="NewIncident.Description">Description</label>
        <textarea asp-for="NewIncident.Description" class="form-control"></textarea>
    </div>
    <div class="form-group">
        <label asp-for="NewIncident.Location">Location</label>
        <input asp-for="NewIncident.Location" class="form-control" />
    </div>

    <input type="hidden" asp-for="NewIncident.Status" value="Pending" />

    <button type="submit" class="btn btn-primary">Submit Report</button>
</form>

<hr />

<h2>Recent Incident Reports</h2>
<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Incident Type</th>
            <th>Description</th>
            <th>Location</th>
            <th>Report Date</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var report in Model.IncidentReports)
        {
            <tr>
                <td>@report.Id</td>
                <td>@report.IncidentType</td>
                <td>@report.Description</td>
                <td>@report.Location</td>
                <td>@report.ReportDate.ToShortDateString()</td>
                <td>@report.Status</td>
                <td>
                    <a asp-page="./Details" asp-route-id="@report.Id" class="btn btn-info">View</a>
                    <a asp-page="./Edit" asp-route-id="@report.Id" class="btn btn-warning">Edit</a>
                    <form asp-page="Delete" asp-route-id="@report.Id" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this report?');">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
