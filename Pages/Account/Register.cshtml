@page
@model SmartCampusPortal.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="register-container">
    <h2 class="text-center text-white">Register</h2>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <p>@error.ErrorMessage</p>
            }
        </div>
    }


    <form method="post" class="form-white">
        <div class="form-group">
            <label asp-for="Input.FullName" class="text-dark"></label>
            <input asp-for="Input.FullName" class="form-control" />
            <span asp-validation-for="Input.FullName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.Email" class="text-dark"></label>
            <input asp-for="Input.Email" class="form-control" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.Password" class="text-dark"></label>
            <input asp-for="Input.Password" class="form-control" type="password" />
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-nav">Register</button>
    </form>
</div>
