@page
@model SmartCampusPortal.Pages.EditModel

<div class="container mt-4">
    <div class="card">
        <div class="card-header">
            <h5 class="card-title">Edit Incident Report</h5>
        </div>
        <div class="card-body">
            <form method="post">
                <div class="form-group">
                    <label asp-for="IncidentReport.IncidentType">Incident Type</label>
                    <input asp-for="IncidentReport.IncidentType" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="IncidentReport.Description">Description</label>
                    <textarea asp-for="IncidentReport.Description" class="form-control"></textarea>
                </div>
                <div class="form-group">
                    <label asp-for="IncidentReport.Location">Location</label>
                    <input asp-for="IncidentReport.Location" class="form-control" />
                </div>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </form>
        </div>
        <div class="card-footer text-end">
            <a asp-page="./SOSIndex" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</div>
